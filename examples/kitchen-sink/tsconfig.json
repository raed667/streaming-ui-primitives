{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "paths": {
      "@raed667/streaming-ui-primitives": ["../../src/index.ts"],
      "@raed667/streaming-ui-primitives/adapters": ["../../src/adapters/index.ts"]
    }
  },
  "include": ["src", "server"]
}
